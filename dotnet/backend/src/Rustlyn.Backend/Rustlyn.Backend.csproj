<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Rustlyn.Backend</AssemblyName>
    <RootNamespace>Rustlyn.Backend</RootNamespace>
    <!-- Backend uses reflection-generated binding glue from Rustlyn.Bindings -->
    <IsAotCompatible>false</IsAotCompatible>
    <IsTrimmable>false</IsTrimmable>
    <RustlynBackendIncludeOptionalBindings Condition="'$(RustlynBackendIncludeOptionalBindings)' == ''">true</RustlynBackendIncludeOptionalBindings>
    <DefineConstants Condition="'$(RustlynBackendIncludeOptionalBindings)' == 'true'">$(DefineConstants);RUSTLYN_BACKEND_OPTIONAL_BINDINGS</DefineConstants>
  </PropertyGroup>

  <Target Name="GenerateRustlynBindingGlue" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <GeneratedBindingGlueDirectory>$(IntermediateOutputPath)Generated\</GeneratedBindingGlueDirectory>
      <GeneratedBindingGlueFile>$(GeneratedBindingGlueDirectory)RuntimeBridgeHelpers.Bindings.g.cs</GeneratedBindingGlueFile>
      <GeneratedAvaloniaBindingGlueFile>$(GeneratedBindingGlueDirectory)RuntimeBridgeHelpers.AvaloniaBindings.g.cs</GeneratedAvaloniaBindingGlueFile>
      <GeneratedPowerShellBindingGlueFile>$(GeneratedBindingGlueDirectory)RuntimeBridgeHelpers.PowerShellCmdletBindings.g.cs</GeneratedPowerShellBindingGlueFile>
    </PropertyGroup>
    <MakeDir Directories="$(GeneratedBindingGlueDirectory)" />
    <Exec Command="dotnet run -c &quot;$(Configuration)&quot; --project &quot;$(MSBuildThisFileDirectory)..\Rustlyn.Bindings.Tool\Rustlyn.Bindings.Tool.csproj&quot; -- managed-glue --out &quot;$(GeneratedBindingGlueFile)&quot;" />
    <Exec Condition="'$(RustlynBackendIncludeOptionalBindings)' == 'true'" Command="dotnet run -c &quot;$(Configuration)&quot; --project &quot;$(MSBuildThisFileDirectory)..\Rustlyn.Bindings.Tool\Rustlyn.Bindings.Tool.csproj&quot; -- avalonia-managed-glue --out &quot;$(GeneratedAvaloniaBindingGlueFile)&quot;" />
    <Exec Condition="'$(RustlynBackendIncludeOptionalBindings)' == 'true'" Command="dotnet run -c &quot;$(Configuration)&quot; --project &quot;$(MSBuildThisFileDirectory)..\Rustlyn.Bindings.Tool\Rustlyn.Bindings.Tool.csproj&quot; -- powershell-managed-glue --out &quot;$(GeneratedPowerShellBindingGlueFile)&quot;" />
    <ItemGroup>
      <Compile Include="$(GeneratedBindingGlueFile)" Link="RuntimeBridgeHelpers.Bindings.g.cs" Visible="false" />
      <Compile Condition="'$(RustlynBackendIncludeOptionalBindings)' == 'true'" Include="$(GeneratedAvaloniaBindingGlueFile)" Link="RuntimeBridgeHelpers.AvaloniaBindings.g.cs" Visible="false" />
      <Compile Condition="'$(RustlynBackendIncludeOptionalBindings)' == 'true'" Include="$(GeneratedPowerShellBindingGlueFile)" Link="RuntimeBridgeHelpers.PowerShellCmdletBindings.g.cs" Visible="false" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <ProjectReference Condition="'$(RustlynBackendIncludeOptionalBindings)' == 'true'" Include="..\Rustlyn.AvaloniaSupport\Rustlyn.AvaloniaSupport.csproj" />
    <ProjectReference Include="..\Rustlyn.Bindings\Rustlyn.Bindings.csproj" />
    <ProjectReference Include="..\Rustlyn.Interop\Rustlyn.Interop.csproj" />
    <ProjectReference Include="..\Rustlyn.Os\Rustlyn.Os.csproj" />
    <ProjectReference Condition="'$(RustlynBackendIncludeOptionalBindings)' == 'true'" Include="..\Rustlyn.PowerShellSupport\Rustlyn.PowerShellSupport.csproj" />
    <ProjectReference Include="..\Rustlyn.Runtime\Rustlyn.Runtime.csproj" />
    <PackageReference Include="LLVMSharp.Interop" Version="20.1.2" />
  </ItemGroup>
</Project>
