<Project Sdk="RustMcil.Sdk">
  <PropertyGroup>
    <AssemblyName>msbuild_generated_cargo</AssemblyName>
    <RustEdition>2024</RustEdition>
  </PropertyGroup>
  <ItemGroup>
    <RustReference Include="..\profile_probe">
      <Name>profile_probe</Name>
    </RustReference>
    <RustCrateReference Include="cfg-if">
      <Version>1.0.0</Version>
      <DefaultFeatures>false</DefaultFeatures>
    </RustCrateReference>
  </ItemGroup>
</Project>
